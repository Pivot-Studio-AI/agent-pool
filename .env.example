# ============================================
# AGENT POOL CONFIGURATION
# ============================================
# Copy this file to .env and fill in your actual values
# Do NOT commit the .env file to version control

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
# Use the values from your docker-compose.yml or external PostgreSQL instance
DATABASE_URL=postgresql://agentpool:agentpool@localhost:5432/agentpool

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port for the Express server (default: 3000)
PORT=3000

# Secret API key for authentication between daemon, dashboard, and server
# Generate a strong random string (e.g., using: openssl rand -base64 32)
# This key is shared between all components for authentication
API_KEY=your-secret-api-key-here

# URL where the React dashboard is served (used for notifications)
# In development, this is typically Vite's dev server
# In production, this could be the same as the server URL
DASHBOARD_URL=http://localhost:5173

# ============================================
# DAEMON CONFIGURATION
# ============================================
# Absolute path to the git repository where agents will work
# The daemon will create worktrees as subdirectories of this repo
# Example: /Users/yourname/your-project
REPO_PATH=/path/to/your/repo

# Number of concurrent agent slots (worktrees) to maintain
# Each slot can run one agent at a time
# Recommended: 3-10 depending on your machine's capacity
POOL_SIZE=5

# URL of the Agent Pool server (where the daemon connects)
# Should match where your server is running
SERVER_URL=http://localhost:3000

# How often the daemon polls for new tasks (in milliseconds)
# Lower values = more responsive but higher CPU usage
# Recommended: 3000-10000 (3-10 seconds)
POLL_INTERVAL_MS=3000

# Default Claude model for agents to use
# Available options: claude-sonnet-4-20250514, claude-opus-4-6, claude-haiku-4-5-20251001
# Can be overridden per task
DEFAULT_MODEL=claude-sonnet-4-20250514

# Default target branch for merging agent changes
# Usually 'main' or 'master' depending on your repository
DEFAULT_BRANCH=main

# ============================================
# WHATSAPP BUSINESS API CONFIGURATION
# ============================================
# Required for WhatsApp notifications and commands
# Get these from Meta Business > WhatsApp > API Setup

# WhatsApp Business Phone Number ID (not your phone number)
# Found in your WhatsApp Business API dashboard
WHATSAPP_PHONE_ID=your-phone-id

# Access token for WhatsApp Business API
# Generate this in your Meta Business account
WHATSAPP_ACCESS_TOKEN=your-access-token

# Webhook verification token (you set this when configuring the webhook)
# Use a random string for security
WHATSAPP_VERIFY_TOKEN=your-verify-token

# Your personal phone number (including country code, no + sign)
# Where you'll receive notifications and send commands
# Example: 1234567890 for a US number
WHATSAPP_USER_PHONE=your-phone-number

# ============================================
# TELEGRAM BOT CONFIGURATION (OPTIONAL)
# ============================================
# Alternative to WhatsApp for notifications
# Create a bot by messaging @BotFather on Telegram

# Bot token from @BotFather (format: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11)
TELEGRAM_BOT_TOKEN=your-bot-token

# Your personal chat ID with the bot (get by messaging the bot and using /start)
# Use @userinfobot to find your chat ID, or check bot logs after first message
TELEGRAM_CHAT_ID=your-chat-id

# ============================================
# DEVELOPMENT / DEBUG (OPTIONAL)
# ============================================
# Uncomment these for debugging

# Enable verbose logging
# DEBUG=agent-pool:*

# Skip some validations in development
# NODE_ENV=development
